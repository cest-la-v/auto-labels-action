    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "fp-ts": "^2.16.10",
    "io-ts": "^2.2.22",
    "io-ts-reporters": "^2.0.1",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.0",
