    "build": "bun build.ts",
    "format": "prettier --write .",
    "lint": "eslint --fix .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "fp-ts": "^2.16.11",
